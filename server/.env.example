# Required — generate with: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=

# Database — SQLite path for single-node dev, or postgres://... for production
DATABASE_URL=./data/llmwiki.db

# HTTP
PORT=3000

# File storage roots
STORAGE_PATH=./data/projects
LANCEDB_PATH=./data/vector

# Optional — server-level default LLM provider (users can override in settings)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
