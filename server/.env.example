# Required — generate with: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=

# Database
DATABASE_URL=./data/llmwiki.db

# HTTP
PORT=3000

# File storage roots
STORAGE_PATH=./data/projects
LANCEDB_PATH=./data/vector

# Optional — server-level default LLM (users can override per-user via PATCH /api/v1/settings)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=

# Rate limiting (0 = disabled)
INGEST_RATE_LIMIT_PER_HOUR=20

# Storage quota per user in MB (0 = unlimited)
STORAGE_QUOTA_MB=0
